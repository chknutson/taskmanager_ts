generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  tasks    Task[]
}

model Task {
  id          Int       @id @default(autoincrement())
  user_id     Int
  task        String
  description String
  due_date    DateTime?
  category    Category
  completed   Boolean   @default(false)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  user        User      @relation(fields: [user_id], references: [id])
}

enum Category {
  Work
  Home
  Fittness
  Family
  Personal
}
